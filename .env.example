# ── 서버 ──
PORT=3000
JWT_SECRET=반드시-길고-무작위한-문자열로-변경하세요

# ── 관리자 계정 (최초 실행 시 자동 생성) ──
ADMIN_NAME=admin
ADMIN_PASSWORD=admin1234

# ── 데이터베이스 ──
# sqlite   : 파일 DB (개발/소규모, 기본값 — 별도 설치 불필요)
# postgres : PostgreSQL (운영 배포용, DATABASE_URL 필수)
DB_DRIVER=sqlite
DATABASE_URL=postgres://dasijang:dasijang@localhost:5432/dasijang

# ── 결제 ──
# mock : 모의 결제 (개발용, 기본) / toss : 토스페이먼츠 실연동
PAYMENT_MODE=mock
# https://developers.tosspayments.com 에서 무료 테스트 키 발급
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# 자동 제재: 서로 다른 유저에게 이 횟수 이상 신고되면 상품은 자동 차단, 유저는 휴면 전환
REPORT_AUTO_LIMIT=3

# 로그인 브루트 포스 방어: 같은 IP+계정 조합 연속 실패 허용 횟수 (초과 시 10분 잠금)
LOGIN_ATTEMPT_LIMIT=5
