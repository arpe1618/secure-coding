# ── 서버 ──
PORT=3000
JWT_SECRET=반드시-길고-무작위한-문자열로-변경하세요

# ── 관리자 계정 (최초 실행 시 자동 생성) ──
ADMIN_NAME=admin
ADMIN_PASSWORD=admin1234

# ── 데이터베이스 ──
# sqlite   : 파일 DB (개발/소규모, 기본값 — 별도 설치 불필요)
# postgres : PostgreSQL (운영 배포용, DATABASE_URL 필수)
DB_DRIVER=sqlite
DATABASE_URL=postgres://dasijang:dasijang@localhost:5432/dasijang

# ── 결제 ──
# mock : 모의 결제 (개발용, 기본) / toss : 토스페이먼츠 실연동
PAYMENT_MODE=mock
# https://developers.tosspayments.com 에서 무료 테스트 키 발급
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# 자동 제재: 서로 다른 유저에게 이 횟수 이상 신고되면 상품은 자동 차단, 유저는 휴면 전환
REPORT_AUTO_LIMIT=3

# 로그인 브루트 포스 방어(IP 기준): 한 IP가 10분 내 이 횟수만큼 실패하면 그 IP의 로그인을 10분 제한
LOGIN_ATTEMPT_LIMIT=10

# 1일 상품 등록 한도 (진단서 §4)
DAILY_POST_LIMIT=30
# HTTPS 배포 시 1로 설정 → 쿠키가 HTTPS에서만 전송됨 (진단서 §2)
COOKIE_SECURE=0


# 전역 API 레이트 리밋: IP당 1분 허용 요청 수 (초과 시 429)
# ※ 자동 테스트(tests/e2e.sh) 실행 시엔 한 IP에서 수백 건을 보내므로 크게 설정: API_RATE_LIMIT_PER_MIN=100000
API_RATE_LIMIT_PER_MIN=300
